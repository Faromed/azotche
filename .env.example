# ═══════════════════════════════════════════════════════════════
#  .env.example — Variables d'environnement Azôtché Website
#  Copiez ce fichier en .env.local et remplissez les valeurs.
# ═══════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────
#  DÉVELOPPEMENT LOCAL (npm run dev)
#  Préfixe VITE_ requis pour que Vite expose ces vars au browser.
# ────────────────────────────────────────────────────────────────

# Config Firebase (Project Settings → General → Vos applications → SDK config)
# Cette clé n'est pas un secret serveur : elle identifie le projet Firebase
# côté client. Sa protection se fait via les Règles de sécurité Firestore/
# Storage + la restriction de la clé dans Google Cloud Console.
VITE_FIREBASE_API_KEY=votre_api_key
VITE_FIREBASE_AUTH_DOMAIN=artisan-connect-benin.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=artisan-connect-benin
VITE_FIREBASE_STORAGE_BUCKET=artisan-connect-benin.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=votre_sender_id
VITE_FIREBASE_APP_ID=votre_app_id

# Clé secrète FedaPay pour les tests locaux
# Obtenez-la sur https://dashboard.fedapay.com → API Keys
VITE_FEDAPAY_SECRET=sk_sandbox_votre_cle_ici

# Utiliser le sandbox FedaPay (true = sandbox, false/absent = live)
VITE_FEDAPAY_SANDBOX=true


# ────────────────────────────────────────────────────────────────
#  PRODUCTION (Vercel Dashboard → Settings → Environment Variables)
# ────────────────────────────────────────────────────────────────

# ⚠️ Les 6 variables VITE_FIREBASE_* ci-dessus doivent AUSSI être ajoutées
# ici (Vercel ne lit jamais .env.local, qui est gitignoré) — sinon le build
# de production inline apiKey: undefined et le site lève
# "Firebase: Error (auth/invalid-api-key)" au chargement. Voir
# PROD_ENV_VARS.txt pour la checklist complète prête à copier-coller.

# Les variables suivantes sont utilisées par la route serverless api/fedapay.js

# Clé secrète FedaPay (live)
# FEDAPAY_SECRET_KEY=sk_live_votre_cle_production

# Utiliser le sandbox en production (optionnel, défaut = false)
# FEDAPAY_SANDBOX=false

# Firebase Admin SDK — Service Account
# Générez les credentials sur Firebase Console :
#   → Project Settings → Service Accounts → Generate new private key
# FIREBASE_PROJECT_ID=artisan-connect-benin
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@artisan-connect-benin.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# (optionnel) Restreindre CORS à votre domaine Vercel
# ALLOWED_ORIGIN=https://azotche.vercel.app
